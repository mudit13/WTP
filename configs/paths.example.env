# Copy to configs/paths.env and adjust for your environment. Never commit paths.env.
# These are the canonical container paths (host: /vol2/pitsec_sose26_topic8/sharedDockerDir
# maps to container /pitsec_sose26_topic8).

# Project root inside the container
WTP_ROOT=/pitsec_sose26_topic8

# Interpreters / venvs. There are THREE generation venvs, one per generator.
# DE-FAKE inference runs inside venv_sd15 (it has clip + torch + blipmodels), per the
# team's working run_defake_batch.py. There is no separate "system python" step here.
WTP_PY_SD15=/pitsec_sose26_topic8/venv_sd15/bin/python3
WTP_PY_FLUX1=/pitsec_sose26_topic8/venv_flux1/bin/python3
WTP_PY_STYLEGAN3=/pitsec_sose26_topic8/venv_stylegan3/bin/python3

# Interpreter used for DE-FAKE inference + the analysis scripts in this repo.
WTP_PY_DEFAKE=/pitsec_sose26_topic8/venv_sd15/bin/python3

# Pretrained DE-FAKE checkpoints (BINARY detector only; no attribution head provided)
WTP_DEFAKE_FINETUNE_CLIP=/pitsec_sose26_topic8/models/finetune_clip.pt
WTP_DEFAKE_CLIP_LINEAR=/pitsec_sose26_topic8/models/clip_linear.pt

# DE-FAKE patched code (contains blipmodels package + test.py/train.py)
WTP_DEFAKE_DIR=/pitsec_sose26_topic8/De-Fake-patched

# Ground-truth index + DE-FAKE prediction CSVs (consumed by run_defake_* / merge / scorers)
WTP_MASTER_CSV=/pitsec_sose26_topic8/dataset/master_metadata.csv
WTP_PRED_CSV=/pitsec_sose26_topic8/dataset/defake_predictions.csv
WTP_PRED_DFFD_CSV=/pitsec_sose26_topic8/dataset/defake_predictions_dffd.csv
WTP_PRED_ALL_CSV=/pitsec_sose26_topic8/dataset/defake_predictions_all.csv

# Read-only secondary tools
WTP_GANDCT_DIR=/workspace/GANDCTAnalysis
WTP_GANFP_DIR=/workspace/GANFingerprints

# Datasets
WTP_DFFD_DIR=/share/DeepFake/DFFD_Images
